{
  "name": "playwright-booking-api",
  "version": "1.0.0",
  "description": "Playwright API automation framework for CRUD testing with TypeScript and Allure reporting.",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "test:crud": "npx playwright test tests/booking/booking-crud-e2e.spec.ts",
    "test:negative": "npx playwright test tests/booking/booking-negative.spec.ts",
    "report": "npx playwright show-report",
    "allure:generate": "npx allure generate allure-results --clean -o allure-report",
    "allure:open": "npx allure open allure-report"
  },
  "keywords": [
    "playwright",
    "api-testing",
    "typescript",
    "qa-automation",
    "allure"
  ],
  "author": "Ian Demillo",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "allure-commandline": "^2.34.1",
    "allure-playwright": "^3.4.1"
  }
}